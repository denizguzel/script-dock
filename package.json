{
  "name": "script-dock",
  "displayName": "Script Dock",
  "version": "0.1.0",
  "description": "Run workspace package scripts from a compact VS Code side panel.",
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/denizguzel/script-dock.git"
  },
  "publisher": "scriptdock",
  "type": "commonjs",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "bun run build:extension && bun run build:webviews",
    "build:extension": "tsc -p tsconfig.json",
    "build:webviews": "vite build --config vite.webviews.config.ts",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "knip": "knip",
    "lint": "oxlint && bun run typecheck && bun run knip && bun run format:check",
    "lint:fix": "oxlint --fix && bun run format",
    "package:check": "bun run format && bun run lint && bun run build",
    "package:vsix": "bun run package:check && vsce package --out script-dock.vsix",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p webviews/tsconfig.json",
    "watch": "tsc --watch -p tsconfig.json"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.1",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/vscode": "1.110.0",
    "@vitejs/plugin-react": "6.0.2",
    "@vscode/vsce": "3.9.2",
    "knip": "6.16.1",
    "lucide-react": "1.18.0",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  },
  "contributes": {
    "commands": [
      {
        "command": "scriptDock.pickStatusBarCommand",
        "title": "Run Pinned Script",
        "icon": "$(play-circle)"
      },
      {
        "command": "scriptDock.refreshScripts",
        "title": "Refresh Scripts",
        "icon": "$(refresh)"
      },
      {
        "command": "scriptDock.searchScripts",
        "title": "Search Scripts",
        "icon": "$(search)"
      },
      {
        "command": "scriptDock.createScriptChain",
        "title": "Create Script Chain",
        "icon": "$(combine)"
      },
      {
        "command": "scriptDock.editScriptChain",
        "title": "Edit Script Chain",
        "icon": "$(edit)"
      },
      {
        "command": "scriptDock.addSuggestedChains",
        "title": "Add Suggested Chains",
        "icon": "$(lightbulb)"
      },
      {
        "command": "scriptDock.stopBackgroundStatusBarCommand",
        "title": "Stop Background Run",
        "icon": "$(debug-stop)"
      },
      {
        "command": "scriptDock.resetWorkspacePreferences",
        "title": "Reset Workspace Preferences",
        "icon": "$(discard)"
      },
      {
        "command": "scriptDock.runScript",
        "title": "Run Script",
        "icon": "$(play)"
      },
      {
        "command": "scriptDock.addStatusBarCommand",
        "title": "Pin Script",
        "icon": "$(pin)"
      },
      {
        "command": "scriptDock.removeStatusBarCommand",
        "title": "Unpin Script",
        "icon": "$(pinned)"
      },
      {
        "command": "scriptDock.runStatusBarCommandInBackground",
        "title": "Run in Background",
        "icon": "$(server-process)"
      },
      {
        "command": "scriptDock.runStatusBarCommandInTerminal",
        "title": "Run in Terminal",
        "icon": "$(terminal-cmd)"
      },
      {
        "command": "scriptDock.moveStatusBarCommandsLeft",
        "title": "Move Status Bar Scripts Left",
        "icon": "$(arrow-left)"
      },
      {
        "command": "scriptDock.moveStatusBarCommandsRight",
        "title": "Move Status Bar Scripts Right",
        "icon": "$(arrow-right)"
      },
      {
        "command": "scriptDock.useCompactStatusBar",
        "title": "Use Compact Status Bar",
        "icon": "$(collapse-all)"
      },
      {
        "command": "scriptDock.useExpandedStatusBar",
        "title": "Use Expanded Status Bar",
        "icon": "$(expand-all)"
      },
      {
        "command": "scriptDock.enableAutoClose",
        "title": "Close Terminal on Success",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "scriptDock.disableAutoClose",
        "title": "Keep Terminal Open",
        "icon": "$(debug-continue)"
      },
      {
        "command": "scriptDock.hideScript",
        "title": "Hide from Panel",
        "icon": "$(eye-closed)"
      },
      {
        "command": "scriptDock.showHiddenScript",
        "title": "Show Hidden Script",
        "icon": "$(eye)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "scriptDock",
          "title": "Script Dock",
          "icon": "resources/script-dock-icon.svg"
        }
      ]
    },
    "views": {
      "scriptDock": [
        {
          "id": "scriptDock.scripts",
          "name": "Scripts",
          "type": "webview",
          "icon": "$(play-circle)"
        }
      ]
    },
    "configuration": {
      "title": "Script Dock",
      "properties": {
        "scriptDock.packageManager": {
          "type": "string",
          "enum": [
            "auto",
            "bun",
            "npm",
            "pnpm",
            "yarn"
          ],
          "default": "auto",
          "description": "Package manager used when running scripts."
        },
        "scriptDock.statusBarCommands": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "label"
            ],
            "properties": {
              "label": {
                "type": "string",
                "description": "Short label shown in the status bar."
              },
              "script": {
                "type": "string",
                "description": "Single package script to run."
              },
              "scripts": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Package scripts to run sequentially."
              },
              "packagePath": {
                "type": "string",
                "description": "Workspace-relative package root for this script. Root package uses '.'."
              },
              "icon": {
                "type": "string",
                "description": "VS Code codicon name without the surrounding $()."
              },
              "autoClose": {
                "type": "boolean",
                "description": "Whether to close the terminal after a successful run."
              },
              "executionMode": {
                "type": "string",
                "enum": [
                  "background",
                  "terminal"
                ],
                "description": "How this pinned script runs. Background scripts show spinner/check/error states and write to the Script Dock output. Terminal scripts open a VS Code terminal. When omitted, scripts use terminal mode."
              }
            }
          },
          "default": [],
          "description": "Pinned scripts shown at the top of the Script Dock panel and through the compact status bar picker. Scripts added from the UI are stored in VS Code workspace storage."
        },
        "scriptDock.statusBarAlignment": {
          "type": "string",
          "enum": [
            "left",
            "right"
          ],
          "default": "right",
          "description": "Side of the VS Code status bar where script buttons are shown."
        },
        "scriptDock.showStatusBarScripts": {
          "type": "boolean",
          "default": true,
          "description": "Whether pinned scripts are shown in the VS Code status bar."
        },
        "scriptDock.statusBarPriority": {
          "type": "number",
          "default": 10000,
          "description": "Base priority for script buttons in the VS Code status bar. Higher values appear earlier within the selected side."
        },
        "scriptDock.statusBarPriorityStep": {
          "type": "number",
          "default": 10,
          "description": "Priority gap between adjacent script buttons. Increase this when other extensions appear between script buttons."
        },
        "scriptDock.statusBarDisplayMode": {
          "type": "string",
          "enum": [
            "compact",
            "expanded"
          ],
          "default": "expanded",
          "description": "Whether pinned scripts are shown as individual status bar buttons or one compact Script Dock picker."
        },
        "scriptDock.statusBarOverflowLimit": {
          "type": "number",
          "default": 6,
          "description": "Maximum expanded status bar buttons before the rest move into a single overflow picker. Use 0 to disable overflow."
        },
        "scriptDock.includeNestedGitRepositories": {
          "type": "boolean",
          "default": false,
          "description": "Whether package.json files inside nested Git repositories should be scanned. Keep this disabled when opening a parent folder that contains many separate repositories."
        },
        "scriptDock.hideScripts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Optional script names hidden from the panel and quick picks. Scripts hidden from the UI are stored in VS Code workspace storage."
        },
        "scriptDock.autoCloseScripts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Script names whose terminal closes automatically after a successful run."
        }
      }
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "resources/script-dock-icon.png",
  "engines": {
    "vscode": ">=1.110.0"
  },
  "packageManager": "bun@1.3.14"
}
