{
  "name": "script-dock",
  "displayName": "Script Dock",
  "version": "0.0.1",
  "private": true,
  "description": "Run workspace package scripts from a compact VS Code side panel.",
  "categories": [
    "Other"
  ],
  "publisher": "scriptdock",
  "type": "commonjs",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "knip": "knip",
    "lint": "oxlint && bun run typecheck && bun run knip && bun run format:check",
    "lint:fix": "oxlint --fix && bun run format",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "watch": "tsc --watch -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "@types/vscode": "1.120.0",
    "knip": "6.16.1",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "typescript": "6.0.3"
  },
  "contributes": {
    "commands": [
      {
        "command": "scriptDock.pickFavoriteScript",
        "title": "Run Favorite Script",
        "icon": "$(terminal)"
      },
      {
        "command": "scriptDock.pickStatusBarCommand",
        "title": "Run Status Bar Script",
        "icon": "$(list-selection)"
      },
      {
        "command": "scriptDock.refreshScripts",
        "title": "Refresh Scripts",
        "icon": "$(refresh)"
      },
      {
        "command": "scriptDock.searchScripts",
        "title": "Search Scripts",
        "icon": "$(search)"
      },
      {
        "command": "scriptDock.createScriptChain",
        "title": "Create Script Chain",
        "icon": "$(combine)"
      },
      {
        "command": "scriptDock.addSuggestedChains",
        "title": "Add Suggested Chains",
        "icon": "$(lightbulb)"
      },
      {
        "command": "scriptDock.showRunHistory",
        "title": "Show Run History",
        "icon": "$(history)"
      },
      {
        "command": "scriptDock.resetWorkspacePreferences",
        "title": "Reset Workspace Preferences",
        "icon": "$(discard)"
      },
      {
        "command": "scriptDock.runScript",
        "title": "Run Script",
        "icon": "$(play)"
      },
      {
        "command": "scriptDock.addFavorite",
        "title": "Add to Favorites",
        "icon": "$(star-empty)"
      },
      {
        "command": "scriptDock.removeFavorite",
        "title": "Remove from Favorites",
        "icon": "$(star-full)"
      },
      {
        "command": "scriptDock.addStatusBarCommand",
        "title": "Show in Status Bar",
        "icon": "$(pin)"
      },
      {
        "command": "scriptDock.removeStatusBarCommand",
        "title": "Remove from Status Bar",
        "icon": "$(pinned)"
      },
      {
        "command": "scriptDock.runStatusBarCommandInBackground",
        "title": "Run in Background",
        "icon": "$(server-process)"
      },
      {
        "command": "scriptDock.runStatusBarCommandInTerminal",
        "title": "Run in Terminal",
        "icon": "$(terminal-cmd)"
      },
      {
        "command": "scriptDock.stopChainOnFailure",
        "title": "Stop Chain on Failure",
        "icon": "$(debug-step-out)"
      },
      {
        "command": "scriptDock.continueChainOnFailure",
        "title": "Continue Chain after Failures",
        "icon": "$(debug-step-over)"
      },
      {
        "command": "scriptDock.moveStatusBarCommandsLeft",
        "title": "Move Status Bar Scripts Left",
        "icon": "$(arrow-left)"
      },
      {
        "command": "scriptDock.moveStatusBarCommandsRight",
        "title": "Move Status Bar Scripts Right",
        "icon": "$(arrow-right)"
      },
      {
        "command": "scriptDock.useCompactStatusBar",
        "title": "Use Compact Status Bar",
        "icon": "$(collapse-all)"
      },
      {
        "command": "scriptDock.useExpandedStatusBar",
        "title": "Use Expanded Status Bar",
        "icon": "$(expand-all)"
      },
      {
        "command": "scriptDock.enableAutoClose",
        "title": "Close Terminal on Success",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "scriptDock.disableAutoClose",
        "title": "Keep Terminal Open",
        "icon": "$(debug-continue)"
      },
      {
        "command": "scriptDock.hideScript",
        "title": "Hide from Panel",
        "icon": "$(eye-closed)"
      },
      {
        "command": "scriptDock.showHiddenScript",
        "title": "Show Hidden Script",
        "icon": "$(eye)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "scriptDock",
          "title": "Script Dock",
          "icon": "resources/script-dock-icon.svg"
        }
      ]
    },
    "views": {
      "scriptDock": [
        {
          "id": "scriptDock.scripts",
          "name": "Scripts",
          "icon": "$(terminal)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "scriptDock.scripts",
        "contents": "No package.json found in this workspace.\n[Refresh Scripts](command:scriptDock.refreshScripts)",
        "when": "scriptDock.hasPackageJson == false"
      },
      {
        "view": "scriptDock.scripts",
        "contents": "No package scripts found. Add a scripts section to package.json, then refresh.\n[Refresh Scripts](command:scriptDock.refreshScripts)",
        "when": "scriptDock.hasPackageJson == true && scriptDock.hasPackageScripts == false"
      },
      {
        "view": "scriptDock.scripts",
        "contents": "All package scripts are hidden.\n[Show Hidden Script](command:scriptDock.showHiddenScript)",
        "when": "scriptDock.hasPackageScripts == true && scriptDock.hasVisibleScripts == false"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "scriptDock.refreshScripts",
          "when": "view == scriptDock.scripts",
          "group": "navigation@2"
        },
        {
          "command": "scriptDock.searchScripts",
          "when": "view == scriptDock.scripts",
          "group": "navigation@1"
        },
        {
          "command": "scriptDock.createScriptChain",
          "when": "view == scriptDock.scripts",
          "group": "actions@2"
        },
        {
          "command": "scriptDock.addSuggestedChains",
          "when": "view == scriptDock.scripts",
          "group": "navigation@3"
        },
        {
          "command": "scriptDock.showRunHistory",
          "when": "view == scriptDock.scripts",
          "group": "actions@3"
        },
        {
          "command": "scriptDock.showHiddenScript",
          "when": "view == scriptDock.scripts",
          "group": "actions@4"
        },
        {
          "command": "scriptDock.resetWorkspacePreferences",
          "when": "view == scriptDock.scripts",
          "group": "manage@9"
        },
        {
          "command": "scriptDock.moveStatusBarCommandsLeft",
          "when": "view == scriptDock.scripts && scriptDock.statusBarAlignment == right",
          "group": "manage@1"
        },
        {
          "command": "scriptDock.moveStatusBarCommandsRight",
          "when": "view == scriptDock.scripts && scriptDock.statusBarAlignment == left",
          "group": "manage@1"
        },
        {
          "command": "scriptDock.useCompactStatusBar",
          "when": "view == scriptDock.scripts && scriptDock.statusBarDisplayMode != compact",
          "group": "navigation@4"
        },
        {
          "command": "scriptDock.useExpandedStatusBar",
          "when": "view == scriptDock.scripts && scriptDock.statusBarDisplayMode == compact",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "scriptDock.runScript",
          "when": "view == scriptDock.scripts && viewItem =~ /\\bscript\\b/",
          "group": "inline@1"
        },
        {
          "command": "scriptDock.addFavorite",
          "when": "view == scriptDock.scripts && viewItem =~ /\\bnotFavorite\\b/",
          "group": "inline@2"
        },
        {
          "command": "scriptDock.removeFavorite",
          "when": "view == scriptDock.scripts && viewItem =~ /\\bfavorite\\b/",
          "group": "inline@2"
        },
        {
          "command": "scriptDock.addStatusBarCommand",
          "when": "view == scriptDock.scripts && viewItem =~ /\\bnotStatusBar\\b/",
          "group": "inline@3"
        },
        {
          "command": "scriptDock.removeStatusBarCommand",
          "when": "view == scriptDock.scripts && viewItem =~ /\\bstatusBar\\b/",
          "group": "inline@3"
        },
        {
          "command": "scriptDock.runStatusBarCommandInBackground",
          "when": "view == scriptDock.scripts && viewItem =~ /\\bstatusBar\\b/ && viewItem =~ /\\bterminalMode\\b/",
          "group": "inline@4"
        },
        {
          "command": "scriptDock.runStatusBarCommandInTerminal",
          "when": "view == scriptDock.scripts && viewItem =~ /\\bstatusBar\\b/ && viewItem =~ /\\bbackgroundMode\\b/",
          "group": "inline@4"
        },
        {
          "command": "scriptDock.continueChainOnFailure",
          "when": "view == scriptDock.scripts && viewItem =~ /\\bstatusBarCommand\\b/ && viewItem =~ /\\bstopOnFailure\\b/",
          "group": "inline@5"
        },
        {
          "command": "scriptDock.stopChainOnFailure",
          "when": "view == scriptDock.scripts && viewItem =~ /\\bstatusBarCommand\\b/ && viewItem =~ /\\bcontinueOnFailure\\b/",
          "group": "inline@5"
        },
        {
          "command": "scriptDock.enableAutoClose",
          "when": "view == scriptDock.scripts && viewItem =~ /\\bnotAutoClose\\b/",
          "group": "inline@6"
        },
        {
          "command": "scriptDock.disableAutoClose",
          "when": "view == scriptDock.scripts && viewItem =~ /\\bautoClose\\b/",
          "group": "inline@6"
        },
        {
          "command": "scriptDock.hideScript",
          "when": "view == scriptDock.scripts && viewItem =~ /\\bscript\\b/",
          "group": "visibility@1"
        }
      ]
    },
    "configuration": {
      "title": "Script Dock",
      "properties": {
        "scriptDock.packageManager": {
          "type": "string",
          "enum": [
            "auto",
            "bun",
            "npm",
            "pnpm",
            "yarn"
          ],
          "default": "auto",
          "description": "Package manager used when running scripts."
        },
        "scriptDock.favoriteScripts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Optional script names pinned at the top of the scripts panel. Scripts added from the UI are stored in VS Code workspace storage."
        },
        "scriptDock.statusBarCommands": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "label"
            ],
            "properties": {
              "label": {
                "type": "string",
                "description": "Short label shown in the status bar."
              },
              "script": {
                "type": "string",
                "description": "Single package script to run."
              },
              "scripts": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Package scripts to run sequentially."
              },
              "packagePath": {
                "type": "string",
                "description": "Workspace-relative package root for this script. Root package uses '.'."
              },
              "icon": {
                "type": "string",
                "description": "VS Code codicon name without the surrounding $()."
              },
              "autoClose": {
                "type": "boolean",
                "description": "Whether to close the terminal after a successful run."
              },
              "executionMode": {
                "type": "string",
                "enum": [
                  "background",
                  "terminal"
                ],
                "description": "How this status bar script runs. Background scripts show spinner/check/error states and write to the Script Dock output. Terminal scripts open a VS Code terminal. When omitted, scripts use terminal mode."
              },
              "failurePolicy": {
                "type": "string",
                "enum": [
                  "stop",
                  "continue"
                ],
                "description": "How script chains handle failed scripts. Stop halts on the first failure. Continue runs the rest of the chain and reports failure at the end."
              }
            }
          },
          "default": [],
          "description": "Optional one-click scripts shown directly in the VS Code status bar. Scripts added from the UI are stored in VS Code workspace storage."
        },
        "scriptDock.statusBarAlignment": {
          "type": "string",
          "enum": [
            "left",
            "right"
          ],
          "default": "left",
          "description": "Side of the VS Code status bar where script buttons are shown."
        },
        "scriptDock.statusBarPriority": {
          "type": "number",
          "default": 10000,
          "description": "Base priority for script buttons in the VS Code status bar. Higher values appear earlier within the selected side."
        },
        "scriptDock.statusBarPriorityStep": {
          "type": "number",
          "default": 10,
          "description": "Priority gap between adjacent script buttons. Increase this when other extensions appear between script buttons."
        },
        "scriptDock.statusBarDisplayMode": {
          "type": "string",
          "enum": [
            "compact",
            "expanded"
          ],
          "default": "expanded",
          "description": "Whether status bar scripts are shown as individual buttons or one compact Script Dock picker."
        },
        "scriptDock.statusBarOverflowLimit": {
          "type": "number",
          "default": 6,
          "description": "Maximum expanded status bar script buttons before the rest move into a single overflow picker. Use 0 to disable overflow."
        },
        "scriptDock.includeNestedGitRepositories": {
          "type": "boolean",
          "default": false,
          "description": "Whether package.json files inside nested Git repositories should be scanned. Keep this disabled when opening a parent folder that contains many separate repositories."
        },
        "scriptDock.hideScripts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Optional script names hidden from the panel and quick picks. Scripts hidden from the UI are stored in VS Code workspace storage."
        },
        "scriptDock.autoCloseScripts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Script names whose terminal closes automatically after a successful run."
        }
      }
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "engines": {
    "vscode": ">=1.105.0"
  },
  "packageManager": "bun@1.3.14"
}
